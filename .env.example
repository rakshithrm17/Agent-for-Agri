# ─────────────────────────────────────────────
# Crop Intelligence Agent — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# Phase 1: SQLite (zero setup)
DATABASE_URL=sqlite:///./crop_agent.db

# Phase 2: PostgreSQL on Supabase (uncomment when ready)
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/crop_agent

# ── Application ───────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
LOG_DIR=crop_agent/logs

# ── Mandya District Coordinates ───────────────
MANDYA_LATITUDE=12.5234
MANDYA_LONGITUDE=76.8961
DEFAULT_DISTRICT=Mandya
DEFAULT_STATE=Karnataka

# ── Open-Meteo (no API key needed — free tier) ─
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive

# ── NASA POWER API (no key needed — free) ──────
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point

# ── SoilGrids API (no key needed — free) ───────
SOILGRIDS_BASE_URL=https://rest.soilgrids.org/soilgrids/v2.0/properties/query

# ── Agmarknet / data.gov.in ────────────────────
# Register at: https://data.gov.in/user/register
# Then get your API key from your profile page
AGMARKNET_API_KEY=your_api_key_here
AGMARKNET_BASE_URL=https://api.data.gov.in/resource/35985678-0d79-46b4-9ed6-6f13308a1d24

# ── News RSS Feeds ────────────────────────────
IMD_RSS_URL=https://mausam.imd.gov.in/imd_latest/contents/rss/cyclone_warning.xml
DD_KISAN_RSS_URL=https://ddkisan.gov.in/rss

# ── Scheduler ─────────────────────────────────
# Night agent runs at 1:00 AM daily
NIGHT_AGENT_HOUR=1
NIGHT_AGENT_MINUTE=0
# Monthly retrain: first Sunday at 3:00 AM
MONTHLY_RETRAIN_HOUR=3
MONTHLY_RETRAIN_MINUTE=0

# ── Model Storage ─────────────────────────────
MODELS_DIR=crop_agent/models

# ── Dashboard ─────────────────────────────────
DASHBOARD_PAGE_TITLE=Crop Intelligence Agent — Mandya
DASHBOARD_HOST=localhost
DASHBOARD_PORT=8501
