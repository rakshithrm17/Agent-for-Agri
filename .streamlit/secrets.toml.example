# ─────────────────────────────────────────────────────────────────
# Streamlit Cloud Secrets Template
# Copy this to .streamlit/secrets.toml locally (NEVER commit secrets.toml)
# On Streamlit Cloud: add these under App Settings → Secrets
# ─────────────────────────────────────────────────────────────────

# Google Earth Engine project (for live Sentinel-2 NDVI)
GEE_PROJECT_ID = "your-gee-project-id"

# Open-Meteo Weather API (free, no key needed — leave blank)
# OPEN_METEO_API_KEY = ""

# Database (leave blank for SQLite on Streamlit Cloud)
DATABASE_URL = "sqlite:///./crop_agent.db"

# Default location
MANDYA_LATITUDE  = "12.5234"
MANDYA_LONGITUDE = "76.8961"
DEFAULT_DISTRICT = "Mandya"
DEFAULT_STATE    = "Karnataka"
